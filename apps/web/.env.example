# Copy this file to apps/web/.env.local and adjust paths for your machine.

# SQLite database used by the web app and Drizzle migration command.
APK_RESEARCHER_DB_PATH=./.data/app-researcher.sqlite

# Uploaded APKs, extracted icons, screenshots, and other local media.
APK_RESEARCHER_STORAGE_DIR=./.data

# Android SDK Build Tools.
# macOS Android Studio default:
# /Users/YOUR_USER/Library/Android/sdk/build-tools/YOUR_BUILD_TOOLS_VERSION/aapt2
# /Users/YOUR_USER/Library/Android/sdk/build-tools/YOUR_BUILD_TOOLS_VERSION/apksigner
APK_RESEARCHER_AAPT2_PATH=/Users/YOUR_USER/Library/Android/sdk/build-tools/37.0.0/aapt2
APK_RESEARCHER_APKSIGNER_PATH=/Users/YOUR_USER/Library/Android/sdk/build-tools/37.0.0/apksigner

# Upload and analysis limits.
APK_RESEARCHER_MAX_UPLOAD_MB=200
APK_RESEARCHER_ANALYSIS_TIMEOUT_MS=30000
